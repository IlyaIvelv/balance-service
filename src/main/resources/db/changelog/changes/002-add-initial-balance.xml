<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="002" author="ilya">
        <addColumn tableName="account">
            <column name="initial_balance" type="DECIMAL(19,2)" defaultValue="0.00">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <!-- Заполняем существующие записи: initial_balance = balance -->
        <sql>UPDATE account SET initial_balance = balance WHERE initial_balance IS NULL OR initial_balance = 0;</sql>
    </changeSet>
</databaseChangeLog>